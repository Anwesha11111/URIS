<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>STEAMI Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <style>
    :root {
      --bg-deep: #080a0f;
      --bg-sidebar: #0c0e14;
      --bg-card: rgba(13, 15, 22, 0.90);
      --bg-glass: rgba(255, 255, 255, 0.04);
      --bg-glass-hover: rgba(255, 255, 255, 0.07);
      --border-hair: rgba(255, 255, 255, 0.07);
      --border-strong: rgba(255, 255, 255, 0.12);
      --white: #ffffff;
      --off-white: #f0f0f0;
      --gray-300: #d1d5db;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-600: #4b5563;
      --green: #22c55e;
      --green-dim: rgba(34, 197, 94, 0.14);
      --red: #ef4444;
      --red-dim: rgba(239, 68, 68, 0.14);
      --neutral-dim: rgba(255, 255, 255, 0.10);
      --radius-card: 20px;
      --radius-pill: 9999px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg-deep);
      color: var(--white);
      display: flex;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    /* ── AMBIENT BACKGROUND ── */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 900px 600px at -10% 0%, rgba(70, 110, 200, 0.15) 0%, transparent 60%),
        radial-gradient(ellipse 600px 500px at 110% 100%, rgba(50, 90, 180, 0.10) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      position: fixed;
      left: 0; top: 0;
      width: 240px;
      height: 100vh;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border-hair);
      display: flex;
      flex-direction: column;
      padding: 28px 20px;
      overflow-y: auto;
      z-index: 10;
    }
    /* subtle side glow */
    .sidebar::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 300px;
      background: radial-gradient(ellipse at 0% 0%, rgba(80, 120, 210, 0.08) 0%, transparent 70%);
      pointer-events: none;
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 36px;
      position: relative;
    }
    .sidebar-logo-icon { width: 32px; height: 32px; flex-shrink: 0; }
    .sidebar-logo-name {
      font-weight: 800;
      font-size: 17px;
      letter-spacing: 0.05em;
      color: var(--white);
    }
    .sidebar-logo-name span { color: var(--gray-400); }

    .sidebar-section-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gray-600);
      margin-bottom: 10px;
      margin-top: 24px;
      padding: 0 4px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border-radius: 10px;
      cursor: pointer;
      font-size: 13.5px;
      font-weight: 500;
      color: var(--gray-500);
      transition: background .15s, color .15s;
      margin-bottom: 2px;
      border: 1px solid transparent;
    }
    .nav-item:hover { background: var(--bg-glass); color: var(--gray-300); }
    .nav-item.active {
      background: var(--bg-glass);
      color: var(--white);
      border-color: var(--border-hair);
    }
    .nav-item i { width: 16px; height: 16px; flex-shrink: 0; }

    .badge {
      margin-left: auto;
      font-size: 10px;
      font-weight: 700;
      padding: 2px 7px;
      border-radius: var(--radius-pill);
      background: var(--white);
      color: var(--bg-deep);
      letter-spacing: 0.03em;
    }

    .sidebar-divider { height: 1px; background: var(--border-hair); margin: 16px 0; }
    .sidebar-spacer { flex: 1; }

    /* Unlock AI card */
    .unlock-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-card);
      padding: 16px;
      cursor: pointer;
      transition: border-color .2s;
      margin-top: 8px;
    }
    .unlock-card:hover { border-color: rgba(255,255,255,0.22); }
    .unlock-card-head {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }
    .unlock-card-head i { width: 15px; height: 15px; color: var(--white); opacity: 0.7; }
    .unlock-card-head span { font-size: 13px; font-weight: 700; color: var(--white); }
    .unlock-card p { font-size: 11.5px; color: var(--gray-500); }

    /* ── MAIN ── */
    .main {
      flex: 1;
      margin-left: 240px;
      padding: 36px 32px;
      position: relative;
      z-index: 1;
    }

    /* ── HEADER ── */
    .page-header { margin-bottom: 32px; }
    .page-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gray-600);
      margin-bottom: 8px;
    }
    .page-header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .page-title {
      font-size: 26px;
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.02em;
    }
    .header-actions { display: flex; align-items: center; gap: 12px; }
    .notif-btn {
      position: relative;
      width: 36px; height: 36px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: background .15s;
    }
    .notif-btn:hover { background: var(--bg-glass-hover); }
    .notif-btn i { width: 16px; height: 16px; color: var(--gray-400); }
    .notif-dot {
      position: absolute;
      top: 7px; right: 7px;
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--white);
    }
    .search-bar {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      border-radius: var(--radius-pill);
      padding: 8px 14px;
      transition: border-color .2s;
    }
    .search-bar:focus-within { border-color: var(--border-strong); }
    .search-bar i { width: 14px; height: 14px; color: var(--gray-500); }
    .search-bar input {
      background: none;
      border: none;
      outline: none;
      color: var(--white);
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      width: 120px;
    }
    .search-bar input::placeholder { color: var(--gray-600); }

    /* ── GRID ── */
    .grid-2-1 { display: grid; grid-template-columns: 1fr 340px; gap: 20px; margin-bottom: 20px; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }

    /* ── CARD ── */
    .card {
      background: var(--bg-card);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border-hair);
      border-radius: var(--radius-card);
      padding: 28px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.25);
      position: relative;
      overflow: hidden;
    }
    /* subtle top highlight */
    .card::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
      pointer-events: none;
    }

    .card-title {
      font-size: 12.5px;
      font-weight: 700;
      color: var(--white);
      letter-spacing: 0.01em;
      margin-bottom: 20px;
    }
    .card-eyebrow {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-600);
      margin-bottom: 6px;
    }

    /* ── SCORE CARD ── */
    .score-big {
      font-size: 44px;
      font-weight: 800;
      color: var(--white);
      letter-spacing: -0.03em;
      line-height: 1;
    }
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 3px 10px;
      border-radius: var(--radius-pill);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.03em;
      margin-top: 10px;
    }
    .pill-green { background: var(--green-dim); color: var(--green); }
    .pill-red { background: var(--red-dim); color: var(--red); }
    .pill-neutral { background: var(--neutral-dim); color: var(--gray-400); }

    .score-header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 24px;
    }

    /* Time tabs */
    .time-tabs {
      display: flex;
      gap: 2px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      border-radius: var(--radius-pill);
      padding: 3px;
    }
    .time-tab {
      padding: 5px 12px;
      border-radius: var(--radius-pill);
      font-size: 11px;
      font-weight: 600;
      color: var(--gray-500);
      cursor: pointer;
      transition: background .15s, color .15s;
      font-family: 'Inter', sans-serif;
      letter-spacing: 0.02em;
    }
    .time-tab:hover { color: var(--gray-300); }
    .time-tab.active {
      background: var(--white);
      color: var(--bg-deep);
    }

    /* Chart */
    .chart-wrap { position: relative; }
    .chart-canvas { width: 100%; height: 110px; }
    .chart-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--gray-600);
    }

    /* ── QUICK ACTIONS ── */
    .quick-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      border-radius: 12px;
      cursor: pointer;
      transition: background .15s, border-color .15s;
      margin-bottom: 10px;
    }
    .quick-item:hover { background: var(--bg-glass-hover); border-color: var(--border-strong); }
    .quick-item-icon {
      width: 28px; height: 28px;
      border-radius: 8px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      flex-shrink: 0;
    }
    .quick-item-label { font-size: 13px; font-weight: 500; color: var(--white); }
    .quick-item i { margin-left: auto; width: 14px; height: 14px; color: var(--gray-600); }

    .streak-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
    }
    .streak-row i { width: 15px; height: 15px; color: var(--gray-400); }
    .streak-row span { font-size: 12.5px; color: var(--gray-500); }
    .streak-row strong { color: var(--white); font-weight: 600; }

    .btn-primary {
      width: 100%;
      background: var(--white);
      color: var(--bg-deep);
      border: none;
      padding: 12px 18px;
      border-radius: var(--radius-pill);
      font-size: 13.5px;
      font-weight: 700;
      font-family: 'Inter', sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      cursor: pointer;
      transition: transform .2s, box-shadow .2s;
      letter-spacing: 0.01em;
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 28px -8px rgba(255,255,255,0.2);
    }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      text-align: left;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--gray-600);
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border-hair);
    }
    thead th:last-child { text-align: right; }
    tbody tr { transition: background .12s; }
    tbody tr:hover { background: rgba(255,255,255,0.025); }
    td {
      padding: 14px 0;
      font-size: 13px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      color: var(--gray-400);
    }
    td:first-child { color: var(--white); }
    td:last-child { text-align: right; }

    .module-cell { display: flex; align-items: center; gap: 10px; }
    .module-icon {
      width: 28px; height: 28px;
      border-radius: 8px;
      background: var(--bg-glass);
      border: 1px solid var(--border-hair);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
    }
    .module-sub { font-size: 11px; color: var(--gray-600); margin-top: 1px; }

    .rank-badge {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 7px;
      border: 1px solid var(--border-hair);
      font-size: 10.5px;
      font-weight: 600;
      color: var(--gray-500);
      letter-spacing: 0.04em;
    }
    .score-val { font-weight: 700; color: var(--white); }

    /* ── DONUT / LEGEND ── */
    .legend-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 11.5px;
      margin-bottom: 8px;
    }
    .legend-left { display: flex; align-items: center; gap: 7px; }
    .legend-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .legend-label { color: var(--gray-500); }
    .legend-val { font-weight: 700; color: var(--white); }

    /* ── RECENT / EVENTS ── */
    .feed-item { padding: 12px 0; border-bottom: 1px solid var(--border-hair); }
    .feed-item:last-child { border-bottom: none; }
    .feed-item p { font-size: 13px; color: var(--white); margin-bottom: 7px; }
    .feed-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .feed-time { font-size: 10.5px; color: var(--gray-600); font-weight: 500; letter-spacing: 0.04em; }
    .tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.03em;
    }
    .tag-green { background: var(--green-dim); color: var(--green); }
    .tag-neutral { background: var(--neutral-dim); color: var(--gray-400); }
  </style>
</head>
<body>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <svg class="sidebar-logo-icon" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="4" fill="white" opacity="0.9"/>
        <circle cx="16" cy="16" r="10" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="1"/>
        <circle cx="16" cy="16" r="14.5" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="0.8" transform="rotate(45 16 16)"/>
      </svg>
      <div class="sidebar-logo-name">STEAM<span>I</span></div>
    </div>

    <!-- Main Nav -->
    <nav>
      <div class="nav-item active">
        <i data-lucide="grid-3x3"></i>
        Dashboard
      </div>
      <div class="nav-item">
        <i data-lucide="book-open"></i>
        Research
      </div>
      <div class="nav-item">
        <i data-lucide="library"></i>
        Publications
      </div>
    </nav>

    <!-- Modules -->
    <div class="sidebar-section-label">Modules</div>
    <div class="sidebar-divider" style="margin-top:0"></div>
    <nav>
      <div class="nav-item">
        <span style="font-size:14px">🔬</span>
        Science
        <span class="badge">New</span>
      </div>
      <div class="nav-item">
        <span style="font-size:14px">⚙️</span>
        Engineering
      </div>
      <div class="nav-item">
        <span style="font-size:14px">🧮</span>
        Mathematics
      </div>
    </nav>

    <div class="sidebar-spacer"></div>
    <div class="sidebar-divider"></div>

    <!-- Bottom Actions -->
    <nav style="margin-bottom:12px">
      <div class="nav-item">
        <i data-lucide="user"></i>
        Profile
      </div>
      <div class="nav-item">
        <i data-lucide="settings"></i>
        Settings
      </div>
      <div class="nav-item">
        <i data-lucide="help-circle"></i>
        Support
      </div>
    </nav>

    <!-- Unlock AI -->
    <div class="unlock-card">
      <div class="unlock-card-head">
        <i data-lucide="sparkles"></i>
        <span>Unlock STEAMI AI</span>
      </div>
      <p>Personalized research copilot</p>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main">

    <!-- Header -->
    <header class="page-header">
      <p class="page-eyebrow">Research / Dashboard</p>
      <div class="page-header-row">
        <h1 class="page-title">Main Dashboard</h1>
        <div class="header-actions">
          <div class="notif-btn">
            <i data-lucide="bell"></i>
            <div class="notif-dot"></div>
          </div>
          <div class="search-bar">
            <i data-lucide="search"></i>
            <input type="text" placeholder="Search">
          </div>
        </div>
      </div>
    </header>

    <!-- Top Row: Score + Quick Actions -->
    <div class="grid-2-1">

      <!-- Research Score Card -->
      <div class="card">
        <div class="card-eyebrow">Research Score</div>
        <div class="score-header">
          <div>
            <div class="score-big">1,247 pts</div>
            <div class="pill pill-green">▲ +47.3%</div>
          </div>
          <div class="time-tabs">
            <button class="time-tab">1D</button>
            <button class="time-tab">7D</button>
            <button class="time-tab">1M</button>
            <button class="time-tab active">1Y</button>
          </div>
        </div>
        <div class="chart-wrap">
          <canvas id="researchChart" class="chart-canvas"></canvas>
          <div class="chart-labels">
            <span>Sep</span><span>Jan</span><span>May</span>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="card" style="display:flex;flex-direction:column;">
        <div class="card-title">Quick Actions</div>
        <div class="quick-item">
          <div class="quick-item-icon">🔬</div>
          <div class="quick-item-label">Science</div>
          <i data-lucide="chevron-down"></i>
        </div>
        <div class="streak-row">
          <i data-lucide="flame"></i>
          <span>Active Streak: <strong>18 days</strong></span>
        </div>
        <div style="flex:1"></div>
        <button class="btn-primary">
          Log Contribution
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </div>
    </div>

    <!-- Active Modules Table -->
    <div class="card" style="margin-bottom:20px;">
      <div class="card-title">Active Modules</div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Module</th>
              <th>Contributions</th>
              <th>Rank</th>
              <th>Score</th>
              <th>Change</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>
                <div class="module-cell">
                  <div class="module-icon">🔬</div>
                  <div>
                    <div>Science</div>
                    <div class="module-sub">STEAM · core</div>
                  </div>
                </div>
              </td>
              <td>24</td>
              <td><span class="rank-badge">Rank 3</span></td>
              <td class="score-val">890 pts</td>
              <td><span class="pill pill-green" style="display:inline-flex;">▲ +120</span></td>
            </tr>
            <tr>
              <td>
                <div class="module-cell">
                  <div class="module-icon">⚙️</div>
                  <div>
                    <div>Engineering</div>
                    <div class="module-sub">STEAM · applied</div>
                  </div>
                </div>
              </td>
              <td>15</td>
              <td><span class="rank-badge">Rank 7</span></td>
              <td class="score-val">610 pts</td>
              <td><span class="pill pill-green" style="display:inline-flex;">▲ +64</span></td>
            </tr>
            <tr>
              <td>
                <div class="module-cell">
                  <div class="module-icon">🧮</div>
                  <div>
                    <div>Mathematics</div>
                    <div class="module-sub">STEAM · pure</div>
                  </div>
                </div>
              </td>
              <td>9</td>
              <td><span class="rank-badge">Rank 12</span></td>
              <td class="score-val">340 pts</td>
              <td><span class="pill pill-red" style="display:inline-flex;">▼ −12</span></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Bottom Row -->
    <div class="grid-3">

      <!-- Domain Distribution -->
      <div class="card">
        <div class="card-title">Domain Distribution</div>
        <canvas id="domainChart" class="chart-canvas" style="height:110px;margin-bottom:16px;"></canvas>
        <div class="legend-item">
          <div class="legend-left"><div class="legend-dot" style="background:#e5e7eb"></div><span class="legend-label">Science</span></div>
          <span class="legend-val">24%</span>
        </div>
        <div class="legend-item">
          <div class="legend-left"><div class="legend-dot" style="background:#9ca3af"></div><span class="legend-label">Technology</span></div>
          <span class="legend-val">22%</span>
        </div>
        <div class="legend-item">
          <div class="legend-left"><div class="legend-dot" style="background:#6b7280"></div><span class="legend-label">Engineering</span></div>
          <span class="legend-val">18%</span>
        </div>
        <div class="legend-item">
