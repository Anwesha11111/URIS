  <script>
    lucide.createIcons();

    // ── Research Score Chart ──
    const researchCanvas = document.getElementById('researchChart');
    if (researchCanvas) {
      const ctx = researchCanvas.getContext('2d');
      const parent = researchCanvas.parentElement;
      const dpr = window.devicePixelRatio || 1;
      const w = parent.offsetWidth;
      const h = 110;
      researchCanvas.width = w * dpr;
      researchCanvas.height = h * dpr;
      researchCanvas.style.width = w + 'px';
      researchCanvas.style.height = h + 'px';
      ctx.scale(dpr, dpr);

      const data = [8, 12, 18, 15, 22, 28, 32, 45, 38, 42, 50];
      const padding = { top: 8, bottom: 8, left: 4, right: 4 };
      const chartW = w - padding.left - padding.right;
      const chartH = h - padding.top - padding.bottom;
      const maxVal = 60;
      const step = chartW / (data.length - 1);

      // Gridlines
      ctx.strokeStyle = 'rgba(255,255,255,0.05)';
      ctx.lineWidth = 1;
      for (let i = 0; i <= 3; i++) {
        const y = padding.top + (chartH / 3) * i;
        ctx.beginPath();
        ctx.moveTo(padding.left, y);
        ctx.lineTo(w - padding.right, y);
        ctx.stroke();
      }

      // Build path
      const pts = data.map((val, i) => ({
        x: padding.left + step * i,
        y: padding.top + chartH - (val / maxVal) * chartH
      }));

      // Gradient fill
      const gradient = ctx.createLinearGradient(0, padding.top, 0, h);
      gradient.addColorStop(0, 'rgba(255, 255, 255, 0.10)');
      gradient.addColorStop(1, 'rgba(255, 255, 255, 0.00)');

      ctx.beginPath();
      ctx.moveTo(pts[0].x, h - padding.bottom);
      pts.forEach(p => ctx.lineTo(p.x, p.y));
      ctx.lineTo(pts[pts.length - 1].x, h - padding.bottom);
      ctx.closePath();
      ctx.fillStyle = gradient;
      ctx.fill();

      // Line (smooth)
      ctx.beginPath();
      ctx.moveTo(pts[0].x, pts[0].y);
      for (let i = 1; i < pts.length; i++) {
        const prev = pts[i - 1];
        const curr = pts[i];
        const cpx = (prev.x + curr.x) / 2;
        ctx.bezierCurveTo(cpx, prev.y, cpx, curr.y, curr.x, curr.y);
      }
      ctx.strokeStyle = 'rgba(255,255,255,0.7)';
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // End dot
      const last = pts[pts.length - 1];
      ctx.fillStyle = '#ffffff';
      ctx.beginPath();
      ctx.arc(last.x, last.y, 4, 0, Math.PI * 2);
      ctx.fill();

      ctx.strokeStyle = 'rgba(255,255,255,0.3)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.arc(last.x, last.y, 9, 0, Math.PI * 2);
      ctx.stroke();
    }

    // ── Domain Chart (donut) ──
    const domainCanvas = document.getElementById('domainChart');
    if (domainCanvas) {
      const ctx = domainCanvas.getContext('2d');
      const parent = domainCanvas.parentElement;
      const dpr = window.devicePixelRatio || 1;
      const w = parent.offsetWidth;
      const h = 110;
      domainCanvas.width = w * dpr;
      domainCanvas.height = h * dpr;
      domainCanvas.style.width = w + 'px';
      domainCanvas.style.height = h + 'px';
      ctx.scale(dpr, dpr);

      const cx = w / 2, cy = h / 2, r = 38;
      const segments = [
        { color: '#e5e7eb', value: 24 },
        { color: '#9ca3af', value: 22 },
        { color: '#6b7280', value: 18 },
        { color: '#4b5563', value: 16 },
        { color: '#374151', value: 12 },
        { color: '#1f2937', value: 8 }
      ];

      let startAngle = -Math.PI / 2;
      segments.forEach(seg => {
        const slice = (seg.value / 100) * Math.PI * 2;
        ctx.fillStyle = seg.color;
        ctx.beginPath();
        ctx.moveTo(cx, cy);
        ctx.arc(cx, cy, r, startAngle, startAngle + slice);
        ctx.closePath();
        ctx.fill();
        startAngle += slice;
      });

      // Donut hole
      ctx.fillStyle = '#0c0e14';
      ctx.beginPath();
      ctx.arc(cx, cy, r * 0.58, 0, Math.PI * 2);
      ctx.fill();

      // Center text
      ctx.fillStyle = 'rgba(255,255,255,0.7)';
      ctx.font = '700 12px Inter, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('STEAM', cx, cy);
    }
  </script>
