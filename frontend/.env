
#VITE_API_URL=https://uris-backend.onrender.com
VITE_API_URL=http://localhost:5000

# ── Manual Onboarding Mode ────────────────────────────────────────────────────
# Mirror of backend EMAIL_DELIVERY_MODE.
# When true: UI shows "Manual Delivery Mode" banner, email status badge shows
# MANUAL, per-row copy buttons are prominent, no "email sent" success message.
# When false (or absent): normal Resend email flow assumed.
VITE_MANUAL_ONBOARDING_MODE=true