generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String
  role       Role       @default(TECHNICAL_INTERN)
  createdAt  DateTime   @default(now())
  status     String     @default("active")
  name       String     @default("")
  activities Activity[]
  auditLogs  AuditLog[]
  intern     Intern?
  teams      UserTeam[]
}

model Intern {
  id                String             @id @default(uuid())
  userId            String?            @unique
  createdAt         DateTime           @default(now())
  overrideScore     Float?
  reservedUntil     DateTime?
  availabilitySlots AvailabilitySlot[]
  capacityScore     CapacityScore?
  credibility       CredibilityScore?
  user              User?              @relation(fields: [userId], references: [id])
  digests           InternDigest[]
  reviews           Review[]
  scoreHistory      ScoreHistory[]
  syncLogs          SyncLog[]
  tasks             Task[]
}

model AvailabilitySlot {
  id                String   @id @default(uuid())
  internId          String
  weekStart         DateTime @db.Date
  weekEnd           DateTime @db.Date
  maxFreeBlockHours Decimal
  busyBlocks        Json
  submittedAt       DateTime @default(now()) @updatedAt
  intern            Intern   @relation(fields: [internId], references: [id])

  @@unique([internId, weekStart])
}

model Task {
  id            String    @id @default(uuid())
  planeTaskId   String    @unique
  internId      String
  title         String
  complexity    Float
  progressPct   Int       @default(0)
  status        String    @default("active")
  hasBlocker    Boolean   @default(false)
  blockerType   String?
  skills        String[]
  deadline      DateTime?
  lastUpdatedAt DateTime
  createdAt     DateTime  @default(now())
  alerts        Alert[]
  reviews       Review[]
  intern        Intern    @relation(fields: [internId], references: [id])
}

model CredibilityScore {
  id                 String   @id @default(uuid())
  internId           String   @unique
  updateFrequency    Float
  deadlineAdherence  Float
  throughputAccuracy Float
  score              Float
  computedAt         DateTime @default(now())
  intern             Intern   @relation(fields: [internId], references: [id])
}

model CapacityScore {
  id            String   @id @default(uuid())
  internId      String   @unique
  baseCapacity  Float
  tli           Float
  credibility   Float
  finalCapacity Float
  capacityLabel String
  updatedAt     DateTime @default(now())
  intern        Intern   @relation(fields: [internId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  internId   String
  quality    Float
  timeliness Float
  initiative Float
  complexity Float
  createdAt  DateTime @default(now())
  taskId     String?
  intern     Intern   @relation(fields: [internId], references: [id])
  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model Alert {
  id        String   @id @default(uuid())
  internId  String
  type      String
  taskId    String?
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  severity  String   @default("warning")
  task      Task?    @relation(fields: [taskId], references: [id])

  @@index([internId])
  @@index([internId, resolved])
  @@index([severity])
  @@index([resolved])
}

model ScoreHistory {
  id        String   @id @default(uuid())
  internId  String
  score     Float
  type      String
  createdAt DateTime @default(now())
  intern    Intern   @relation(fields: [internId], references: [id])

  @@index([createdAt])
  @@index([internId, type, createdAt(sort: Desc)])
}

model SyncLog {
  id        String   @id @default(uuid())
  internId  String?
  filename  String
  status    String   @default("SUCCESS")
  error     String?
  createdAt DateTime @default(now())
  intern    Intern?  @relation(fields: [internId], references: [id])
}

model Team {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  members     UserTeam[]
}

model UserTeam {
  id       String    @id @default(uuid())
  userId   String
  teamId   String
  role     String    @default("member")
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  team     Team      @relation(fields: [teamId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([teamId])
  @@index([leftAt])
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  type      String
  duration  Int?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model Config {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt
}

model ApprovalRequest {
  id            String    @id @default(uuid())
  action        String
  targetId      String
  targetType    String
  requestedById String
  payload       Json
  status        String    @default("pending")
  reviewedById  String?
  reviewNote    String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([requestedById])
  @@index([reviewedById])
  @@index([status])
  @@index([action])
  @@index([createdAt])
}

model BlockedIP {
  id          String    @id @default(uuid())
  ipAddress   String    @unique
  reason      String?
  expiresAt   DateTime?
  blockedById String?
  blockedAt   DateTime  @default(now())

  @@index([ipAddress])
}

model LoginLog {
  id        String   @id @default(uuid())
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([success])
  @@index([createdAt])
}

model UserRoleHistory {
  id           String   @id @default(uuid())
  userId       String
  previousRole String
  newRole      String
  changedById  String?
  reason       String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ArchivedUser {
  id           String   @id @default(uuid())
  originalId   String   @unique
  snapshot     Json
  status       String   @default("ARCHIVED")
  archivedAt   DateTime @default(now())
  archivedById String?

  @@index([status])
  @@index([archivedAt])
}

model InternDigest {
  id               String   @id @default(uuid())
  internId         String
  weekStart        DateTime @db.Date
  capacityScore    Float
  credibilityScore Float
  performanceIndex Float
  activeTasks      Int
  completedTasks   Int
  openAlerts       Int
  generatedAt      DateTime @default(now())
  intern           Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)

  @@unique([internId, weekStart])
  @@index([internId])
  @@index([weekStart])
}

enum Role {
  CORE_ADMIN
  TECHNICAL_LEAD
  OPERATIONS_LEAD
  RESEARCH_LEAD
  OPERATIONS_PROGRAM_MANAGER
  TECHNICAL_INTERN
  OPERATIONS_INTERN
  RESEARCH_INTERN
  OBSERVER_TEAM_LEAD
  COLLABORATOR_LEAD
  ORENDA_MEMBER
  PAST_EMPLOYEE
}
