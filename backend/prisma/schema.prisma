// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  CORE_ADMIN
  TECHNICAL_LEAD
  OPERATIONS_LEAD
  RESEARCH_LEAD
  OPERATIONS_PROGRAM_MANAGER
  TECHNICAL_INTERN
  OPERATIONS_INTERN
  RESEARCH_INTERN
  OBSERVER_TEAM_LEAD
  COLLABORATOR_LEAD
  ORENDA_MEMBER
  PAST_EMPLOYEE
}

// UserStatus — enterprise lifecycle states for a user account.
// ACTIVE   : normal, can log in
// INACTIVE : temporarily disabled (e.g. on leave), cannot log in
// ARCHIVED : soft-archived, data preserved, cannot log in
// REMOVED  : marked for removal, data preserved for compliance
//
// The existing `status` TEXT column on User is kept for backward compatibility
// and continues to drive auth logic ("active" | "pending" | "alumni").
// This enum is used by the new ArchivedUser model and will gradually replace
// the free-text column in a future migration.
enum UserStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
  REMOVED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id         String     @id @default(uuid())
  email      String     @unique
  password   String     // bcrypt hash only — never plain text
  name       String     @default("")   // display name supplied at registration
  role       Role       @default(TECHNICAL_INTERN)
  status     String     @default("active")  // "active" | "pending" | "alumni"
  createdAt  DateTime   @default(now())
  intern     Intern?
  teams      UserTeam[]
  activities Activity[]
  auditLogs  AuditLog[]
  supportRequests SupportRequest[]
}

model Intern {
  id                String            @id @default(uuid())
  userId            String?           @unique
  user              User?             @relation(fields: [userId], references: [id])
  
  // Public Portfolio Data
  slug              String?           @unique // for stemonef.com/portfolio/john-doe
  profilePic        String?
  contactNumber     String?
  bio               String?
  linkedinUrl       String?
  skills            String[]          @default([])
  
  overrideScore     Float?
  reservedUntil     DateTime?         // soft reservation expiry
  createdAt         DateTime          @default(now())
  availabilitySlots AvailabilitySlot[]
  tasks             Task[]
  credibility       CredibilityScore?
  capacityScore     CapacityScore?
  reviews           Review[]
  scoreHistory      ScoreHistory[]
  digests           InternDigest[]
  syncLogs          SyncLog[]
}

model AvailabilitySlot {
  id                String   @id @default(uuid())
  internId          String
  intern            Intern   @relation(fields: [internId], references: [id])
  weekStart         DateTime @db.Date
  weekEnd           DateTime @db.Date
  maxFreeBlockHours Decimal
  busyBlocks        Json
  submittedAt       DateTime @default(now()) @updatedAt

  @@unique([internId, weekStart])
}

model Task {
  id            String    @id @default(uuid())
  planeTaskId   String    @unique
  internId      String
  title         String
  complexity    Float
  progressPct   Int       @default(0)
  status        String    @default("active")
  hasBlocker    Boolean   @default(false)
  blockerType   String?
  skills        String[]
  deadline      DateTime?
  lastUpdatedAt DateTime
  deletedAt     DateTime? // Soft delete - tasks removed for wrong assignment etc.
  
  // Visibility & Access metadata
  isOperational Boolean   @default(false)
  teamId        String?
  observerIds   String[]  @default([])
  collaboratorIds String[] @default([])

  createdAt     DateTime  @default(now())

  intern        Intern    @relation(fields: [internId], references: [id])
  reviews       Review[]
  alerts        Alert[]
}

model CredibilityScore {
  id                 String   @id @default(uuid())
  internId           String   @unique
  updateFrequency    Float
  deadlineAdherence  Float
  throughputAccuracy Float
  score              Float
  computedAt         DateTime @default(now())

  intern             Intern   @relation(fields: [internId], references: [id])
}

model CapacityScore {
  id            String   @id @default(uuid())
  internId      String   @unique
  baseCapacity  Float
  tli           Float
  credibility   Float
  finalCapacity Float
  capacityLabel String
  updatedAt     DateTime @default(now())

  intern        Intern   @relation(fields: [internId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  internId   String
  intern     Intern   @relation(fields: [internId], references: [id])
  taskId     String?
  task       Task?    @relation(fields: [taskId], references: [id])
  quality    Float
  timeliness Float
  initiative Float
  complexity Float
  createdAt  DateTime @default(now())

  @@unique([internId, taskId], name: "Review_internId_taskId_key", map: "Review_internId_taskId_key")
  @@index([taskId])
}

model Alert {
  id        String   @id @default(uuid())
  internId  String
  type      String
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  message   String
  severity  String   @default("warning")  // "warning" | "critical"
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([internId])
  @@index([severity])
  @@index([resolved])
  @@index([internId, resolved])
}

model ScoreHistory {
  id        String   @id @default(uuid())
  internId  String
  intern    Intern   @relation(fields: [internId], references: [id])
  score     Float
  type      String   // "performance" | "credibility" | "capacity"
  createdAt DateTime @default(now())

  @@index([internId, type, createdAt(sort: Desc)])
  @@index([createdAt])
}

model SyncLog {
  id        String   @id @default(uuid())
  internId  String?
  intern    Intern?  @relation(fields: [internId], references: [id], onDelete: SetNull)
  filename  String
  status    String   @default("SUCCESS") // "SUCCESS" | "FAILED"
  error     String?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Multi-Team Support
// ---------------------------------------------------------------------------

model Team {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  members     UserTeam[]
}

model UserTeam {
  id       String    @id @default(uuid())
  userId   String
  teamId   String
  role     String    @default("member")  // "member" | "lead" — enforced by DB CHECK constraint
  joinedAt DateTime  @default(now())
  leftAt   DateTime?                     // null = currently active member

  user     User      @relation(fields: [userId], references: [id])
  team     Team      @relation(fields: [teamId], references: [id])

  @@index([userId])
  @@index([teamId])
  @@index([leftAt])
}

// ---------------------------------------------------------------------------
// Activity Tracking
// ---------------------------------------------------------------------------

model Activity {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String                        // ACTIVITY_TYPES constant: LOGIN, LOGOUT, TASK_WORK, IDLE
  duration  Int?                          // seconds; null for point-in-time events (LOGIN/LOGOUT)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

// ---------------------------------------------------------------------------
// Audit Log
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?                      // null for system-generated events
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String                       // e.g. "LOGIN", "CREATE_TASK"
  entity    String                       // e.g. "USER", "TASK", "SCORE"
  entityId  String?                      // id of the affected record
  metadata  Json?                        // arbitrary extra context
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// System Config
// ---------------------------------------------------------------------------

model Config {
  key       String   @id                 // unique setting name, e.g. "availabilityDeadline"
  value     Json                         // arbitrary JSON value
  updatedAt DateTime @default(now()) @updatedAt
}

// ---------------------------------------------------------------------------
// Weekly Digest
// ---------------------------------------------------------------------------
// One row per intern per week. Written by the digest scheduler every Monday.
// Provides a point-in-time snapshot for trend analysis and admin review.

model InternDigest {
  id               String   @id @default(uuid())
  internId         String
  intern           Intern   @relation(fields: [internId], references: [id], onDelete: Cascade)
  weekStart        DateTime @db.Date      // Monday of the digest week
  capacityScore    Float                  // snapshot from ScoreHistory
  credibilityScore Float                  // snapshot from CredibilityScore
  performanceIndex Float                  // rolling RPI at time of digest
  activeTasks      Int
  completedTasks   Int
  openAlerts       Int
  generatedAt      DateTime @default(now())

  @@unique([internId, weekStart])
  @@index([internId])
  @@index([weekStart])
}

// ---------------------------------------------------------------------------
// User Archive Foundation (Phase 1)
// ---------------------------------------------------------------------------
// Preserves a complete snapshot of a user record at the time of archival.
// This is an additive, non-destructive model — no existing data is touched.
//
// Lifecycle:
//   ACTIVE → INACTIVE → ARCHIVED → REMOVED
//
// The original User row is NOT deleted. ArchivedUser is a point-in-time
// snapshot written by the archive workflow (to be implemented in Phase 2).
// The `status` field uses the new UserStatus enum for type safety.
//
// archivedBy is nullable to support system-initiated archival (e.g. scheduler).

model ArchivedUser {
  id           String     @id @default(uuid())
  originalId   String     @unique          // the User.id that was archived
  snapshot     Json                        // full user record at time of archival
  status       UserStatus @default(ARCHIVED)
  archivedAt   DateTime   @default(now())
  archivedById String?                     // User.id of the admin who triggered archival

  @@index([originalId])
  @@index([archivedAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// User Role History (Phase 2 — Feature 7)
// ---------------------------------------------------------------------------
// Tracks every role change for a user, enabling promotion-safe architecture.
// The user's identity (User.id) is preserved across all role changes.
// No data is deleted — this is an append-only audit trail.
//
// changedById is nullable to support system-initiated role changes.
// previousRole / newRole use the Role enum for type safety.

model UserRoleHistory {
  id           String   @id @default(uuid())
  userId       String                        // the user whose role changed
  previousRole Role                          // role before the change
  newRole      Role                          // role after the change
  changedAt    DateTime @default(now())
  changedById  String?                       // admin who made the change (null = system)
  reason       String?                       // optional justification

  @@index([userId])
  @@index([changedAt])
}

// ---------------------------------------------------------------------------
// Login Log (Phase 2 — Feature 8)
// ---------------------------------------------------------------------------
// Records every login attempt (success and failure) with IP and user-agent.
// Used for security auditing and anomaly detection foundation.
// userId is nullable — failed attempts for unknown emails have no userId.

model LoginLog {
  id          String   @id @default(uuid())
  userId      String?                        // null for failed attempts with unknown email
  email       String                         // attempted email (always recorded)
  ipAddress   String                         // client IP (from X-Forwarded-For or socket)
  userAgent   String?                        // User-Agent header
  success     Boolean                        // true = successful login, false = failed
  failReason  String?                        // e.g. "invalid_password", "pending_account"
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([email])
  @@index([createdAt])
  @@index([success])
}

// ---------------------------------------------------------------------------
// Blocked IP (Phase 2 — Feature 8)
// ---------------------------------------------------------------------------
// Stores IP addresses that are blocked from accessing the system.
// Blocking is enforced by the ipBlock middleware before any route handler runs.
// expiresAt is nullable — null means the block is permanent.
// blockedById is nullable to support automated/system-initiated blocks.

model BlockedIP {
  id          String    @id @default(uuid())
  ipAddress   String    @unique              // the blocked IP (IPv4 or IPv6)
  reason      String?                        // human-readable reason for the block
  blockedAt   DateTime  @default(now())
  expiresAt   DateTime?                      // null = permanent block
  blockedById String?                        // admin who created the block

  @@index([ipAddress])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Support Request (Phase 3 — Feature 3, extended in Phase 5)
// ---------------------------------------------------------------------------
// Allows interns to contact operations/admins/leads for blockers, emergencies,
// and operational concerns. Lightweight — not a full chat system.
//
// status lifecycle: OPEN → IN_PROGRESS → RESOLVED | CLOSED
// priority:         LOW | MEDIUM | HIGH | URGENT | CRITICAL
// category:         TECHNICAL_ISSUE | ACCESS_PROBLEM | EMERGENCY | TASK_BLOCKER
//                   HR_OPERATIONS | INFRASTRUCTURE | GENERAL | OTHER

model SupportRequest {
  id            String    @id @default(cuid())
  userId        String                        // the user who submitted the request
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String                        // short summary (max 120 chars)
  message       String                        // full message body
  priority      String    @default("MEDIUM")  // LOW | MEDIUM | HIGH | URGENT | CRITICAL
  category      String    @default("GENERAL") // see category constants above
  status        String    @default("OPEN")    // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  assignedToId  String?                       // admin/lead assigned to handle this
  internalNotes String?                       // admin/ops only — never returned to interns
  closedById    String?                       // who closed/resolved the request
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@index([assignedToId])
}
