// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  INTERN
  ADMIN
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String     // bcrypt hash only — never plain text
  role      Role       @default(INTERN)
  createdAt DateTime   @default(now())
  intern    Intern?
  teams     UserTeam[]
}

model Intern {
  id                String            @id @default(uuid())
  userId            String?           @unique
  user              User?             @relation(fields: [userId], references: [id])
  overrideScore     Float?
  createdAt         DateTime          @default(now())
  availabilitySlots AvailabilitySlot[]
  tasks             Task[]
  credibility       CredibilityScore?
  capacityScore     CapacityScore?
  reviews           Review[]
  scoreHistory      ScoreHistory[]
}

model AvailabilitySlot {
  id                String   @id @default(uuid())
  internId          String
  intern            Intern   @relation(fields: [internId], references: [id])
  weekStart         DateTime @db.Date
  weekEnd           DateTime @db.Date
  maxFreeBlockHours Decimal
  busyBlocks        Json
  submittedAt       DateTime @default(now()) @updatedAt

  @@unique([internId, weekStart])
}

model Task {
  id            String    @id @default(uuid())
  planeTaskId   String    @unique
  internId      String
  title         String
  complexity    Float
  progressPct   Int       @default(0)
  status        String    @default("active")
  hasBlocker    Boolean   @default(false)
  blockerType   String?
  skills        String[]
  deadline      DateTime?
  lastUpdatedAt DateTime
  createdAt     DateTime  @default(now())

  intern        Intern    @relation(fields: [internId], references: [id])
}

model CredibilityScore {
  id                 String   @id @default(uuid())
  internId           String   @unique
  updateFrequency    Float
  deadlineAdherence  Float
  throughputAccuracy Float
  score              Float
  computedAt         DateTime @default(now())

  intern             Intern   @relation(fields: [internId], references: [id])
}

model CapacityScore {
  id            String   @id @default(uuid())
  internId      String   @unique
  baseCapacity  Float
  tli           Float
  credibility   Float
  finalCapacity Float
  capacityLabel String
  updatedAt     DateTime @default(now())

  intern        Intern   @relation(fields: [internId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  internId   String
  intern     Intern   @relation(fields: [internId], references: [id])
  quality    Float
  timeliness Float
  initiative Float
  complexity Float
  createdAt  DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())
  internId  String
  type      String
  taskId    String?
  message   String
  severity  String   @default("warning")  // "warning" | "critical"
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([internId])
  @@index([severity])
  @@index([resolved])
}

model ScoreHistory {
  id        String   @id @default(uuid())
  internId  String
  intern    Intern   @relation(fields: [internId], references: [id])
  score     Float
  type      String   // "performance" | "credibility" | "capacity"
  createdAt DateTime @default(now())
}

model SyncLog {
  id        String   @id @default(uuid())
  internId  String?
  filename  String
  status    String   @default("SUCCESS") // "SUCCESS" | "FAILED"
  error     String?
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Multi-Team Support
// ---------------------------------------------------------------------------

model Team {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  members     UserTeam[]
}

model UserTeam {
  id       String    @id @default(uuid())
  userId   String
  teamId   String
  role     String    @default("member")  // "member" | "lead"
  joinedAt DateTime  @default(now())
  leftAt   DateTime?                     // null = currently active member

  user     User      @relation(fields: [userId], references: [id])
  team     Team      @relation(fields: [teamId], references: [id])

  @@index([userId])
  @@index([teamId])
  @@index([leftAt])
}

// ---------------------------------------------------------------------------
// Activity Tracking
// ---------------------------------------------------------------------------

model Activity {
  id        String   @id @default(uuid())
  userId    String                        // always set — activity is user-specific
  type      String                        // ACTIVITY_TYPES constant: LOGIN, LOGOUT, TASK_WORK, IDLE
  duration  Int?                          // seconds; null for point-in-time events (LOGIN/LOGOUT)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

// ---------------------------------------------------------------------------
// Audit Log
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?                      // null for system-generated events
  action    String                       // e.g. "LOGIN", "CREATE_TASK"
  entity    String                       // e.g. "USER", "TASK", "SCORE"
  entityId  String?                      // id of the affected record
  metadata  Json?                        // arbitrary extra context
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
