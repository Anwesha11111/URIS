# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"
PRISMA_CLIENT_ENGINE_TYPE="binary"

# Authentication
JWT_SECRET="your_jwt_secret_minimum_32_characters"
JWT_EXPIRES_IN="1d"

# Rate Limiting (Optional — defaults shown)
RATE_LIMIT_LOGIN_WINDOW_MS="900000"
RATE_LIMIT_LOGIN_MAX="10"
RATE_LIMIT_REGISTER_WINDOW_MS="3600000"
RATE_LIMIT_REGISTER_MAX="5"
RATE_LIMIT_API_WINDOW_MS="60000"
RATE_LIMIT_API_MAX="200"

# Auto IP Blocking (Optional — defaults shown)
# Block an IP after FAILED_LOGIN_THRESHOLD failures within FAILED_LOGIN_WINDOW_MS
FAILED_LOGIN_THRESHOLD="5"
FAILED_LOGIN_WINDOW_MS="900000"
IP_BLOCK_DURATION_MS="1800000"
IP_BLOCK_CACHE_TTL_MS="60000"

# Frontend Configuration
FRONTEND_URL="http://localhost:5173"

# Plane.so Integration (Optional/Required in Prod)
PLANE_WEBHOOK_SECRET="your_plane_webhook_secret"
PLANE_BASE_URL="https://plane.yourdomain.com/api/v1"
PLANE_API_KEY="your_plane_api_key"
PLANE_WORKSPACE_SLUG="your_workspace_slug"
PLANE_PROJECT_ID="your_project_uuid"
PLANE_REQUEST_TIMEOUT_MS="10000"

# Nextcloud WebDAV Integration (Optional)
NEXTCLOUD_URL="https://nextcloud.yourdomain.com/remote.php/dav/files/username"
NEXTCLOUD_USERNAME="your_nextcloud_username"
NEXTCLOUD_PASSWORD="your_nextcloud_password"
NEXTCLOUD_REQUEST_TIMEOUT_MS="15000"

# Scheduler Configuration (Optional)
SYNC_INTERVAL_CRON="*/15 * * * *"
DIGEST_CRON="0 8 * * 1"

# Email / SMTP (Required for password reset and notification emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="URIS <noreply@yourdomain.com>"

# GDoc Reminder Cron (Optional — default: every 3 days at 09:00 UTC)
GDOC_REMINDER_CRON="0 9 */3 * *"

# Forgot Password Rate Limiting (Optional — defaults shown)
RATE_LIMIT_FORGOT_WINDOW_MS="900000"
RATE_LIMIT_FORGOT_MAX="5"

# File Upload (Optional locally — REQUIRED in production)
UPLOAD_DIR="uploads/profile-pictures"
APP_BASE_URL="http://localhost:5000"   # Set to your production domain in prod, e.g. https://api.yourdomain.com

# Google OAuth Integration (Required for Google Docs/Drive/Calendar features)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable: Google Drive API, Drive Activity API, Google Calendar API, Google Docs API
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/auth/google/callback"

# GDoc metadata refresh cron (Optional — default: every 6 hours)
GDOC_META_CRON="0 */6 * * *"

# GDoc stale threshold in days (Optional — default: 3)
GDOC_STALE_DAYS="3"

# Resend Email Integration (replaces SMTP — Required for all outbound emails)
# Get your API key at https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM="URIS <noreply@yourdomain.com>"

# ── Email Delivery Mode ───────────────────────────────────────────────────────
# Controls whether the onboarding credential system uses Resend (email) or
# manual clipboard/copy distribution.
#
#   email   → attempt Resend dispatch for every sendCredentials call (default)
#   manual  → skip Resend entirely; return credentials to the UI for manual
#             distribution regardless of whether RESEND_API_KEY is present.
#             Use this during pilot phases when DNS / domain is not yet verified.
#
# When switching back to email mode, just change this value to "email" — no
# other code changes are required.
EMAIL_DELIVERY_MODE="email"

# Pilot temporary password — used when EMAIL_DELIVERY_MODE=manual.
# Distributed manually to all imported users by the Core Admin.
# Must satisfy password strength rules: ≥8 chars, ≥2 capitals, ≥1 special character.
# Ignored when EMAIL_DELIVERY_MODE=email (random per-user password is generated instead).
DEFAULT_TEMP_PASSWORD="Stemonef@2026!"
